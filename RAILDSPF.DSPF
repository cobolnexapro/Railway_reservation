     A* --------------------------------------------------------
     A* ADMINISTRATOR MENU
     A* --------------------------------------------------------
     A          R ADMMNU                     CA03(03)
     A                                       CA12(12)
     A                                  1 30 'ADMINISTRATOR MENU' DSPATR(HI)
     A                                  4 14 '1.  Add / Update Train (Train, Fare & Quota Management)'
     A                                  5 14 '2.  Booking & Revenue Reports'
     A                                  7 10 'Select Option  . . . :'
     A            AMOPTION       1S 0B  7 36 CHECK(MF) RANGE(1 2) ERRMSG('ENTER A VALID OPTION NUMBER' 50)
     A            AMMSG1        60A  O  9 10 DSPATR(HI)
     A                                 23 10 'F3=Exit   F12=Back to Main Menu'
     A
     A* --------------------------------------------------------
     A* TRAIN / FARE / QUOTA MAINTENANCE SCREEN
     A* --------------------------------------------------------
     A          R ADMTRN                     CA03(03)
     A                                       CA12(12)
     A                                       CF10(10)
     A                                  1 22 'TRAIN / FARE / QUOTA MAINTENANCE' DSPATR(HI)
     A                                  3 10 'Train No (0 = new train) . :'
     A            ATTRNNO        5S 0B  3 41 CHECK(MF) EDTCDE(Z)
     A                                  4 10 'Train Name . . . . . . . . :'
     A            ATTRNAM       30A  B  4 41 CHECK(MF)
     A                                  5 10 'Source Station / Code  . . :'
     A            ATSRCST       20A  B  5 41 CHECK(MF)
     A            ATSRCCOD       4A  B  5 63 CHECK(MF)
     A                                  6 10 'Dest. Station / Code . . . :'
     A            ATDSTST       20A  B  6 41 CHECK(MF)
     A            ATDSTCOD       4A  B  6 63 CHECK(MF)
     A                                  7 10 'Departure / Arrival(HHMM) . :'
     A            ATDEPTIM       4S 0B  7 41 CHECK(MF)
     A            ATARRTIM       4S 0B  7 47 CHECK(MF)
     A                                  8 10 'Running Days (Y/N x MTWTFSS):'
     A            ATRUNDAY       7A  B  8 41 CHECK(MF)
     A                                  9 10 'Total Seats  . . . . . . . :'
     A            ATTOTSET       4S 0B  9 41 CHECK(MF)
     A                                 10 10 'Gen / Ladies / Sr.Ctzn Seats:'
     A            ATGENSET       4S 0B 10 41 CHECK(MF)
     A            ATLADSET       4S 0B 10 47 CHECK(MF)
     A            ATSCTSET       4S 0B 10 53 CHECK(MF)
     A                                 11 10 'Base Fare  . . . . . . . . :'
     A            ATFARE         7P 2B 11 41 CHECK(MF)
     A                                 12 10 'Status (A=Active / I=Inactive):'
     A            ATTRNSTS       1A  B 12 44 CHECK(MF) VALUES('A' 'I')
     A            ATMSG1        60A  O 14 10 DSPATR(HI)
     A                                 23 10 'F3=Exit   F10=Save   F12=Back to Admin Menu'
     A
     A* --------------------------------------------------------
     A* BOOKING & REVENUE REPORTS SCREEN
     A* --------------------------------------------------------
     A          R RPTFMT                     CA03(03)
     A                                       CA12(12)
     A                                       CF10(10)
     A                                  1 26 'BOOKING & REVENUE REPORTS' DSPATR(HI)
     A                                  3 10 'Train No (0 = All Trains) . :'
     A            RPTRNNO        5S 0B  3 41 EDTCDE(Z)
     A                                  5 10 'Total Bookings . . . . . . :'
     A            RPTOTBK        6S 0O  5 41 EDTCDE(Z)
     A                                  6 10 'Active Bookings  . . . . . :'
     A            RPACTBK        6S 0O  6 41 EDTCDE(Z)
     A                                  7 10 'Cancelled Bookings . . . . :'
     A            RPCANBK        6S 0O  7 41 EDTCDE(Z)
     A                                  8 10 'Total Revenue Collected  . :'
     A            RPTOTREV       9P 2O  8 41 EDTCDE(1)
     A                                  9 10 'Total Refunds Paid . . . . :'
     A            RPTOTREF       9P 2O  9 41 EDTCDE(1)
     A                                 10 10 'Registered Users . . . . . :'
     A            RPUSRCNT       6S 0O 10 41 EDTCDE(Z)
     A            RPMSG1        60A  O 12 10 DSPATR(HI)
     A                                 23 10 'F3=Exit   F10=Run Report   F12=Back to Admin Menu'
