     A                                  6 10 'Route  . . . . . . . :'
     A            PNSRCST       16A  O  6 36
     A                                  6 53 'TO'
     A            PNDSTST       16A  O  6 56
     A                                  7 10 'Journey Date . . . . :'
     A            PNJRNDAT       8S 0O  7 36 EDTCDE(Z)
     A                                  8 10 'Passenger  . . . . . :'
     A            PNPSGNAM      30A  O  8 36
     A                                  9 10 'Age / Sex  . . . . . :'
     A            PNPSGAGE       3S 0O  9 36 EDTCDE(Z)
     A            PNPSGSEX       1A  O  9 41
     A                                 10 10 'Quota / Berth / No.  :'
     A            PNQUOTA        2A  O 10 36
     A            PNBRTHTY       2A  O 10 40
     A            PNBRTHNO       3S 0O 10 44 EDTCDE(Z)
     A                                 11 10 'Fare Paid  . . . . . :'
     A            PNFARAMT       7P 2O 11 36 EDTCDE(1)
     A                                 12 10 'Booking Status . . . :'
     A            PNBOKSTS       1A  O 12 36
     A                                 13 10 'Refund Amount  . . . :'
     A            PNREFAMT       7P 2O 13 36 EDTCDE(1)
     A            PNMSG1        60A  O 15 10 DSPATR(HI)
     A                                 23 10 'F3=Exit   F10=Lookup   F12=Back to Menu'
